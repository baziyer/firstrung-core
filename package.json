{
  "name": "firstrung-core-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/schema",
    "packages/collector",
    "packages/rules",
    "packages/report",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "check": "npm run build && npm test",
    "release:schema": "npm publish --workspace @firstrung/schema --access public"
  },
  "engines": {
    "node": ">=22.6"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
