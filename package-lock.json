{
  "name": "firstrung-core-workspace",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "firstrung-core-workspace",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=22.6"
      }
    },
    "node_modules/@firstrung/schema": {
      "resolved": "packages/schema",
      "link": true
    },
    "packages/schema": {
      "name": "@firstrung/schema",
      "version": "0.0.0"
    }
  }
}
